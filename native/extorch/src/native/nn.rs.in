// Neural network module creation and operations
// ----------------------------------------------------------------

// Layer factories

/// Create a Linear (fully connected) layer.
fn nn_linear(in_features: i64, out_features: i64, bias: bool) -> Result<SharedPtr<CrossNNModule>>;

/// Create a 1D convolution layer.
fn nn_conv1d(
    in_channels: i64, out_channels: i64, kernel_size: i64,
    stride: i64, padding: i64, dilation: i64, groups: i64, bias: bool,
) -> Result<SharedPtr<CrossNNModule>>;

/// Create a 2D convolution layer.
fn nn_conv2d(
    in_channels: i64, out_channels: i64, kernel_size: i64,
    stride: i64, padding: i64, dilation: i64, groups: i64, bias: bool,
) -> Result<SharedPtr<CrossNNModule>>;

/// Create a 1D batch normalization layer.
fn nn_batch_norm1d(
    num_features: i64, eps: f64, momentum: f64, affine: bool, track_running_stats: bool,
) -> Result<SharedPtr<CrossNNModule>>;

/// Create a 2D batch normalization layer.
fn nn_batch_norm2d(
    num_features: i64, eps: f64, momentum: f64, affine: bool, track_running_stats: bool,
) -> Result<SharedPtr<CrossNNModule>>;

/// Create a layer normalization layer.
fn nn_layer_norm(
    normalized_shape: Vec<i64>, eps: f64, elementwise_affine: bool,
) -> Result<SharedPtr<CrossNNModule>>;

/// Create a dropout layer.
fn nn_dropout(p: f64, inplace: bool) -> Result<SharedPtr<CrossNNModule>>;

/// Create an embedding layer.
fn nn_embedding(
    num_embeddings: i64, embedding_dim: i64, padding_idx: i64, has_padding_idx: bool,
) -> Result<SharedPtr<CrossNNModule>>;

// Activation functions

/// Create a ReLU activation module.
fn nn_relu(inplace: bool) -> Result<SharedPtr<CrossNNModule>>;

/// Create a GELU activation module.
fn nn_gelu() -> Result<SharedPtr<CrossNNModule>>;

/// Create a Sigmoid activation module.
fn nn_sigmoid() -> Result<SharedPtr<CrossNNModule>>;

/// Create a Tanh activation module.
fn nn_tanh() -> Result<SharedPtr<CrossNNModule>>;

/// Create a Softmax activation module.
fn nn_softmax(dim: i64) -> Result<SharedPtr<CrossNNModule>>;

// Additional convolutions

fn nn_conv3d(
    in_channels: i64, out_channels: i64, kernel_size: i64,
    stride: i64, padding: i64, dilation: i64, groups: i64, bias: bool,
) -> Result<SharedPtr<CrossNNModule>>;

fn nn_conv_transpose1d(
    in_channels: i64, out_channels: i64, kernel_size: i64,
    stride: i64, padding: i64, output_padding: i64, groups: i64, bias: bool, dilation: i64,
) -> Result<SharedPtr<CrossNNModule>>;

fn nn_conv_transpose2d(
    in_channels: i64, out_channels: i64, kernel_size: i64,
    stride: i64, padding: i64, output_padding: i64, groups: i64, bias: bool, dilation: i64,
) -> Result<SharedPtr<CrossNNModule>>;

// Pooling

fn nn_max_pool1d(kernel_size: i64, stride: i64, padding: i64, dilation: i64, ceil_mode: bool) -> Result<SharedPtr<CrossNNModule>>;
fn nn_max_pool2d(kernel_size: i64, stride: i64, padding: i64, dilation: i64, ceil_mode: bool) -> Result<SharedPtr<CrossNNModule>>;
fn nn_avg_pool1d(kernel_size: i64, stride: i64, padding: i64, ceil_mode: bool, count_include_pad: bool) -> Result<SharedPtr<CrossNNModule>>;
fn nn_avg_pool2d(kernel_size: i64, stride: i64, padding: i64, ceil_mode: bool, count_include_pad: bool) -> Result<SharedPtr<CrossNNModule>>;
fn nn_adaptive_avg_pool1d(output_size: i64) -> Result<SharedPtr<CrossNNModule>>;
fn nn_adaptive_avg_pool2d(output_h: i64, output_w: i64) -> Result<SharedPtr<CrossNNModule>>;

// Additional normalization

fn nn_group_norm(num_groups: i64, num_channels: i64, eps: f64, affine: bool) -> Result<SharedPtr<CrossNNModule>>;
fn nn_instance_norm1d(num_features: i64, eps: f64, momentum: f64, affine: bool, track_running_stats: bool) -> Result<SharedPtr<CrossNNModule>>;
fn nn_instance_norm2d(num_features: i64, eps: f64, momentum: f64, affine: bool, track_running_stats: bool) -> Result<SharedPtr<CrossNNModule>>;

// Recurrent

fn nn_lstm(input_size: i64, hidden_size: i64, num_layers: i64, bias: bool, batch_first: bool, dropout: f64, bidirectional: bool) -> Result<SharedPtr<CrossNNModule>>;
fn nn_gru(input_size: i64, hidden_size: i64, num_layers: i64, bias: bool, batch_first: bool, dropout: f64, bidirectional: bool) -> Result<SharedPtr<CrossNNModule>>;

// Transformer

fn nn_multihead_attention(embed_dim: i64, num_heads: i64, dropout: f64, bias: bool) -> Result<SharedPtr<CrossNNModule>>;

// Utility

fn nn_flatten(start_dim: i64, end_dim: i64) -> Result<SharedPtr<CrossNNModule>>;
fn nn_unflatten(dim: i64, sizes: Vec<i64>) -> Result<SharedPtr<CrossNNModule>>;

// Additional activations

fn nn_leaky_relu(negative_slope: f64, inplace: bool) -> Result<SharedPtr<CrossNNModule>>;
fn nn_elu(alpha: f64, inplace: bool) -> Result<SharedPtr<CrossNNModule>>;
fn nn_silu() -> Result<SharedPtr<CrossNNModule>>;
fn nn_mish() -> Result<SharedPtr<CrossNNModule>>;
fn nn_prelu(num_parameters: i64) -> Result<SharedPtr<CrossNNModule>>;
fn nn_log_softmax(dim: i64) -> Result<SharedPtr<CrossNNModule>>;

// Module operations

/// Run forward pass on an nn module.
fn nn_forward(
    module: &SharedPtr<CrossNNModule>,
    input: &SharedPtr<CrossTensor>,
) -> Result<SharedPtr<CrossTensor>>;

/// Get named parameters of an nn module.
fn nn_parameters(
    module: &SharedPtr<CrossNNModule>,
) -> Result<Vec<NamedTensor>>;

/// Set an nn module to evaluation mode.
fn nn_set_eval(module: &SharedPtr<CrossNNModule>) -> Result<()>;

/// Set an nn module to training mode.
fn nn_set_train(module: &SharedPtr<CrossNNModule>) -> Result<()>;

/// Get the type name of an nn module.
fn nn_type_name(module: &SharedPtr<CrossNNModule>) -> Result<String>;

/// Copy parameter values from a list of named tensors into a module.
fn nn_copy_parameters(
    dst: &SharedPtr<CrossNNModule>,
    params: Vec<NamedTensor>,
) -> Result<()>;

/// Move an nn module to a different device.
fn nn_to_device(
    module: &SharedPtr<CrossNNModule>,
    s_device: Device,
) -> Result<SharedPtr<CrossNNModule>>;

// Direct ATen functional ops (Phase A)

/// Functional at::lstm. Returns [output, h_n, c_n].
fn aten_lstm(
    input: &SharedPtr<CrossTensor>,
    hx: TensorList,
    params: TensorList,
    has_biases: bool,
    num_layers: i64,
    dropout: f64,
    train: bool,
    bidirectional: bool,
    batch_first: bool,
) -> Result<TensorList>;

/// Functional at::gru. Returns [output, h_n].
fn aten_gru(
    input: &SharedPtr<CrossTensor>,
    hx: &SharedPtr<CrossTensor>,
    params: TensorList,
    has_biases: bool,
    num_layers: i64,
    dropout: f64,
    train: bool,
    bidirectional: bool,
    batch_first: bool,
) -> Result<TensorList>;

/// Functional at::_transformer_encoder_layer_fwd. Returns the layer output.
fn aten_transformer_encoder_layer_fwd(
    src: &SharedPtr<CrossTensor>,
    embed_dim: i64,
    num_heads: i64,
    qkv_weight: &SharedPtr<CrossTensor>,
    qkv_bias: &SharedPtr<CrossTensor>,
    proj_weight: &SharedPtr<CrossTensor>,
    proj_bias: &SharedPtr<CrossTensor>,
    use_gelu: bool,
    norm_first: bool,
    eps: f64,
    norm_weight_1: &SharedPtr<CrossTensor>,
    norm_bias_1: &SharedPtr<CrossTensor>,
    norm_weight_2: &SharedPtr<CrossTensor>,
    norm_bias_2: &SharedPtr<CrossTensor>,
    ffn_weight_1: &SharedPtr<CrossTensor>,
    ffn_bias_1: &SharedPtr<CrossTensor>,
    ffn_weight_2: &SharedPtr<CrossTensor>,
    ffn_bias_2: &SharedPtr<CrossTensor>,
) -> Result<SharedPtr<CrossTensor>>;

/// Functional at::scaled_dot_product_attention.
fn aten_scaled_dot_product_attention(
    query: &SharedPtr<CrossTensor>,
    key: &SharedPtr<CrossTensor>,
    value: &SharedPtr<CrossTensor>,
    dropout_p: f64,
    is_causal: bool,
    scale: f64,
    has_scale: bool,
) -> Result<SharedPtr<CrossTensor>>;

/// Functional at::_native_multi_head_attention. Returns [attn_output, attn_weights].
fn aten_native_multi_head_attention(
    query: &SharedPtr<CrossTensor>,
    key: &SharedPtr<CrossTensor>,
    value: &SharedPtr<CrossTensor>,
    embed_dim: i64,
    num_head: i64,
    qkv_weight: &SharedPtr<CrossTensor>,
    qkv_bias: &SharedPtr<CrossTensor>,
    proj_weight: &SharedPtr<CrossTensor>,
    proj_bias: &SharedPtr<CrossTensor>,
    need_weights: bool,
    average_attn_weights: bool,
) -> Result<TensorList>;

// Direct ATen functional ops (Phase B): conv, norm, pool

fn aten_conv2d(
    input: &SharedPtr<CrossTensor>,
    weight: &SharedPtr<CrossTensor>,
    bias_opt: TensorList,
    stride: Vec<i64>,
    padding: Vec<i64>,
    dilation: Vec<i64>,
    groups: i64,
) -> Result<SharedPtr<CrossTensor>>;

fn aten_conv1d(
    input: &SharedPtr<CrossTensor>,
    weight: &SharedPtr<CrossTensor>,
    bias_opt: TensorList,
    stride: Vec<i64>,
    padding: Vec<i64>,
    dilation: Vec<i64>,
    groups: i64,
) -> Result<SharedPtr<CrossTensor>>;

fn aten_conv3d(
    input: &SharedPtr<CrossTensor>,
    weight: &SharedPtr<CrossTensor>,
    bias_opt: TensorList,
    stride: Vec<i64>,
    padding: Vec<i64>,
    dilation: Vec<i64>,
    groups: i64,
) -> Result<SharedPtr<CrossTensor>>;

fn aten_convolution(
    input: &SharedPtr<CrossTensor>,
    weight: &SharedPtr<CrossTensor>,
    bias_opt: TensorList,
    stride: Vec<i64>,
    padding: Vec<i64>,
    dilation: Vec<i64>,
    transposed: bool,
    output_padding: Vec<i64>,
    groups: i64,
) -> Result<SharedPtr<CrossTensor>>;

fn aten_conv_transpose2d(
    input: &SharedPtr<CrossTensor>,
    weight: &SharedPtr<CrossTensor>,
    bias_opt: TensorList,
    stride: Vec<i64>,
    padding: Vec<i64>,
    output_padding: Vec<i64>,
    groups: i64,
    dilation: Vec<i64>,
) -> Result<SharedPtr<CrossTensor>>;

fn aten_batch_norm(
    input: &SharedPtr<CrossTensor>,
    weight_opt: TensorList,
    bias_opt: TensorList,
    running_mean_opt: TensorList,
    running_var_opt: TensorList,
    training: bool,
    momentum: f64,
    eps: f64,
) -> Result<SharedPtr<CrossTensor>>;

fn aten_layer_norm(
    input: &SharedPtr<CrossTensor>,
    normalized_shape: Vec<i64>,
    weight_opt: TensorList,
    bias_opt: TensorList,
    eps: f64,
) -> Result<SharedPtr<CrossTensor>>;

fn aten_group_norm(
    input: &SharedPtr<CrossTensor>,
    num_groups: i64,
    weight_opt: TensorList,
    bias_opt: TensorList,
    eps: f64,
) -> Result<SharedPtr<CrossTensor>>;

fn aten_max_pool2d(
    input: &SharedPtr<CrossTensor>,
    kernel_size: Vec<i64>,
    stride: Vec<i64>,
    padding: Vec<i64>,
    dilation: Vec<i64>,
    ceil_mode: bool,
) -> Result<SharedPtr<CrossTensor>>;

fn aten_avg_pool2d(
    input: &SharedPtr<CrossTensor>,
    kernel_size: Vec<i64>,
    stride: Vec<i64>,
    padding: Vec<i64>,
    ceil_mode: bool,
    count_include_pad: bool,
) -> Result<SharedPtr<CrossTensor>>;

fn aten_adaptive_avg_pool2d(
    input: &SharedPtr<CrossTensor>,
    output_size: Vec<i64>,
) -> Result<SharedPtr<CrossTensor>>;

// Thread pool / backend inspection
fn aten_get_num_threads() -> Result<i64>;
fn aten_set_num_threads(n: i64) -> Result<()>;
fn aten_get_num_interop_threads() -> Result<i64>;
fn aten_set_num_interop_threads(n: i64) -> Result<()>;
fn aten_mkldnn_is_available() -> Result<bool>;

// Identity (for marshaling overhead measurement)
fn aten_noop(t: &SharedPtr<CrossTensor>) -> Result<SharedPtr<CrossTensor>>;

// Backend / context introspection
fn aten_backend_info() -> Result<String>;
fn aten_is_grad_enabled() -> Result<bool>;
fn aten_set_grad_enabled(enabled: bool) -> Result<()>;
fn aten_clear_cpu_affinity() -> Result<bool>;

// Block until all queued CUDA kernels have completed on the current
// device. No-op on CPU-only libtorch builds.
fn aten_cuda_synchronize() -> Result<()>;

// MKLDNN weight pre-packing
fn aten_mkldnn_reorder_conv2d_weight(
    weight: &SharedPtr<CrossTensor>,
    padding: Vec<i64>,
    stride: Vec<i64>,
    dilation: Vec<i64>,
    groups: i64,
) -> Result<SharedPtr<CrossTensor>>;

fn aten_mkldnn_convolution(
    input: &SharedPtr<CrossTensor>,
    packed_weight: &SharedPtr<CrossTensor>,
    bias_opt: TensorList,
    padding: Vec<i64>,
    stride: Vec<i64>,
    dilation: Vec<i64>,
    groups: i64,
) -> Result<SharedPtr<CrossTensor>>;
