
/// Shared interface to a tensor pointer in memory.
struct CrossTensorRef {
    tensor: SharedPtr<CrossTensor>,
}

/// Torch tensor device descriptor.
struct Device {
    device: String,
    index: i64,
}

/// Scalar number representation
struct Scalar {
    _repr: Vec<u8>,
    entry_used: String
}

struct ScalarList {
    list: Vec<Scalar>,
    size: Vec<i64>
}

struct TorchSlice {
    start: i64,
    stop: i64,
    step: i64,
    enc: u8
}

struct TorchIndex {
    integer: i64,
    boolean: bool,
    slice: TorchSlice,
    tensor: SharedPtr<CrossTensor>,
    type_: i64
}

struct PrintOptions {
    precision: i64,
    threshold: f64,
    edgeitems: i64,
    linewidth: i64,
    sci_mode: u8
}

struct SortResult {
    values: SharedPtr<CrossTensor>,
    indices: SharedPtr<CrossTensor>,
    used: bool
}

struct TensorTuple {
    values: Vec<TensorOut>,
    used: bool
}

struct TensorList {
    values: Vec<TensorOut>,
    used: bool
}

struct OptionalInt {
    value: i64,
    used: bool
}

struct TensorOut {
    tensor: SharedPtr<CrossTensor>,
    used: bool
}

struct TensorOrInt {
    tensor: SharedPtr<CrossTensor>,
    value: i64,
    is_tensor: bool
}

struct IntListOrInt {
    list: Vec<i64>,
    value: i64,
    is_list: bool
}

/// Shared interface to a JIT module pointer in memory.
struct CrossModuleRef {
    module: SharedPtr<CrossModule>,
}

/// Shared interface to an AOTI model loader in memory.
struct CrossAOTILoaderRef {
    loader: SharedPtr<CrossAOTILoader>,
}

/// Shared interface to an nn module pointer in memory.
struct CrossNNModuleRef {
    module: SharedPtr<CrossNNModule>,
}

/// Shared interface to a compiled graph executor in memory.
struct CrossCompiledGraphRef {
    graph: SharedPtr<CrossCompiledGraph>,
}

/// A named tensor (name + tensor pointer), used for parameters/buffers.
struct NamedTensor {
    name: String,
    tensor: SharedPtr<CrossTensor>,
}

/// A single node in a flattened IValue tree.
/// Tags: 0=tensor, 1=int, 2=float, 3=bool, 4=string, 5=none, 6=tuple, 7=list, 8=dict
struct IValueNode {
    tag: i64,
    tensor: SharedPtr<CrossTensor>,
    int_val: i64,
    float_val: f64,
    bool_val: bool,
    string_val: String,
    parent_idx: i64,
    child_count: i64,
}

/// A flattened IValue tree (pre-order traversal).
struct IValueFlat {
    nodes: Vec<IValueNode>,
}

/// Information about a single parameter.
struct ParameterInfo {
    name: String,
    shape: Vec<i64>,
    dtype: String,
    requires_grad: bool,
}

/// Information about a submodule.
struct SubmoduleInfo {
    name: String,
    type_name: String,
    parameters: Vec<ParameterInfo>,
}
